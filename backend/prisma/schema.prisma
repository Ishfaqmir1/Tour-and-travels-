generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentStatus {
  completed
  pending
  failed
  refunded
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
}

model User {
  id                Int       @id @default(autoincrement())
  name              String
  email             String    @unique
  password          String
  phone             String?
  address           String?
  isSuperAdmin      Boolean   @default(false) @map("is_super_admin")
  profilePhotoPath  String?   @map("profile_photo_path")
  emailVerifiedAt   DateTime? @map("email_verified_at")
  rememberToken     String?   @map("remember_token")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  payments  Payment[]
  bookings  Booking[]
  reviews   PackageReview[]
  roles     UserRole[]

  @@map("users")
}

model TourDestination {
  id               Int         @id @default(autoincrement())
  slug             String      @unique
  title            String
  country          String
  city             String
  locationLabel    String      @map("location_label")
  image            String
  shortDescription String      @map("short_description")
  description      String
  duration         String
  price            String
  rating           Float       @default(0)
  bestSeason       String?     @map("best_season")
  thingsToDo       String?     @map("things_to_do")
  nearbyAttractions String?    @map("nearby_attractions")
  metaTitle        String?     @map("meta_title")
  metaDescription  String?     @map("meta_description")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  guides  TourGuide[]
  gallery GalleryItem[]
  packages Package[]

  @@map("tour_destinations")
}

model TourGuide {
  id              Int              @id @default(autoincrement())
  destinationId   Int?             @map("destination_id")
  name            String
  photo           String
  description     String
  rating          Int              @default(5)
  location        String
  experienceYears Int              @map("experience_years")
  languages       String
  hireCost        Decimal?         @map("hire_cost")
  phone           String?
  email           String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  destination TourDestination? @relation(fields: [destinationId], references: [id])
  payments    Payment[]

  @@map("tour_guides")
}

model Package {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  title           String
  image           String
  images          String?  @map("images") // JSON array of gallery images
  video           String?
  location        String
  country         String
  destinationId   Int?     @map("destination_id")
  duration        String
  price           Decimal
  discountPercent Int?     @default(0) @map("discount_percent")
  rating          Float    @default(0)
  reviewCount     Int      @default(0) @map("review_count")
  overview        String
  highlights      String?  // JSON array
  included        String?  // JSON array
  excluded        String?  // JSON array
  hotels          String?  // JSON array
  meals           String?  // JSON array
  transportation  String?
  bestSeason      String?  @map("best_season")
  cancellationPolicy String? @map("cancellation_policy")
  isFeatured      Boolean  @default(false) @map("is_featured")
  isActive        Boolean  @default(true) @map("is_active")
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  destination TourDestination? @relation(fields: [destinationId], references: [id])
  days        PackageDay[]
  faqs        PackageFAQ[]
  reviews     PackageReview[]
  bookings    Booking[]

  @@map("packages")
}

model PackageDay {
  id          Int     @id @default(autoincrement())
  packageId   Int     @map("package_id")
  dayNumber   Int     @map("day_number")
  title       String
  description String
  activities  String? // JSON array of activities
  meals       String?
  hotel       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@map("package_days")
}

model PackageFAQ {
  id        Int      @id @default(autoincrement())
  packageId Int      @map("package_id")
  question  String
  answer    String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@map("package_faqs")
}

model PackageReview {
  id        Int      @id @default(autoincrement())
  packageId Int      @map("package_id")
  userId    Int      @map("user_id")
  rating    Int
  comment   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([packageId, userId])
  @@map("package_reviews")
}

model Booking {
  id              Int           @id @default(autoincrement())
  userId          Int           @map("user_id")
  packageId       Int           @map("package_id")
  transactionId   String        @unique @map("transaction_id")
  amount          Decimal
  currency        String        @default("USD")
  travelers       Int           @default(1)
  status          BookingStatus @default(pending)
  customerName    String        @map("customer_name")
  customerEmail   String        @map("customer_email")
  customerPhone   String?       @map("customer_phone")
  specialRequests String?       @map("special_requests")
  travelDate      DateTime?     @map("travel_date")
  paidAt          DateTime?     @map("paid_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id])
  package Package @relation(fields: [packageId], references: [id])

  @@map("bookings")
}

model Payment {
  id              Int           @id @default(autoincrement())
  userId          Int           @map("user_id")
  tourGuideId     Int           @map("tour_guide_id")
  transactionId   String        @unique @map("transaction_id")
  amount          Decimal
  currency        String        @default("USD")
  days            Int           @default(1)
  cardHolderName  String        @map("card_holder_name")
  cardBrand       String        @map("card_brand")
  cardLastFour    String        @map("card_last_four")
  status          PaymentStatus @default(completed)
  paidAt          DateTime      @default(now()) @map("paid_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id])
  guide TourGuide  @relation(fields: [tourGuideId], references: [id])

  @@map("payments")
}

model GalleryItem {
  id            Int      @id @default(autoincrement())
  albumId       Int?     @map("album_id")
  destinationId Int?     @map("destination_id")
  type          String   @default("photo") // "photo" | "video"
  url           String
  thumbnailUrl  String?  @map("thumbnail_url")
  title         String?
  description   String?
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  album       GalleryAlbum?    @relation(fields: [albumId], references: [id])
  destination TourDestination? @relation(fields: [destinationId], references: [id])

  @@map("gallery_items")
}

model GalleryAlbum {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  coverImage  String?       @map("cover_image")
  slug        String        @unique
  sortOrder   Int           @default(0) @map("sort_order")
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  items GalleryItem[]

  @@map("gallery_albums")
}

model Hotel {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  image       String
  images      String?  // JSON array
  location    String
  stars       Int      @default(3)
  description String
  amenities   String?  // JSON array
  pricePerNight Decimal? @map("price_per_night")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("hotels")
}

model Taxi {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  image       String?
  driverName  String?  @map("driver_name")
  driverPhone String?  @map("driver_phone")
  location    String
  type        String   @default("car") // car, van, bus, luxury
  capacity    Int      @default(4)
  pricePerKm  Decimal? @map("price_per_km")
  description String?
  amenities   String?  // JSON array
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("taxis")
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  permissions String?      // JSON array of permission keys
  isSystem    Boolean      @default(false) @map("is_system")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  users UserRole[]

  @@map("roles")
}

model UserRole {
  userId Int    @map("user_id")
  roleId Int    @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  location  String?
  avatar    String?
  content   String
  rating    Int      @default(5)
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("testimonials")
}

model BlogPost {
  id             Int      @id @default(autoincrement())
  slug           String   @unique
  title          String
  content        String
  excerpt        String?
  image          String?
  author         String?
  tags           String?  // JSON array
  isPublished    Boolean  @default(false) @map("is_published")
  publishedAt    DateTime? @map("published_at")
  metaTitle      String?  @map("meta_title")
  metaDescription String? @map("meta_description")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("blog_posts")
}

model GeneralFAQ {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String
  category  String?
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("general_faqs")
}

model WebsiteSetting {
  id              Int      @id @default(autoincrement())
  key             String   @unique
  value           String
  type            String   @default("text") // "text", "image", "json", "rich-text"
  group           String   @default("general") // "general", "hero", "footer", "seo", "social", "contact"
  label           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("website_settings")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("contact_messages")
}

model PasswordReset {
  email     String
  token     String
  createdAt DateTime @default(now()) @map("created_at")

  @@id([email, token])
  @@map("password_resets")
}
